# CodeGuardian AI: Backend Configurations

# Database connection URL (defaults to local SQLite database in workspace)
# Replace with Supabase PostgreSQL connection string in production
DATABASE_URL=sqlite:///./codeguardian.db

# Authentication controls
# Set to 'False' once Clerk credentials are set up on frontend and backend
BYPASS_AUTH=True

# Clerk Secret settings (only needed when BYPASS_AUTH=False)
CLERK_SECRET_KEY=
CLERK_JWKS_URL=
